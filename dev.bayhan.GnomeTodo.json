{
  "app-id": "dev.bayhan.GnomeTodo",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "todogui",
  "finish-args": [
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "blueprint-compiler",
      "buildsystem": "meson",
      "cleanup": ["*"],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler",
          "tag": "v0.18.0"
        }
      ]
    },
    {
      "name": "todogui",
      "builddir": true,
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
