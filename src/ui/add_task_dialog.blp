using Gtk 4.0;
using Adw 1;

template $AddTaskDialog: Adw.Dialog {
  title: "New Task";
  content-width: 480;

  Adw.ToolbarView {
    [top]
    Adw.HeaderBar {
      [start]
      Gtk.Button {
        label: "Cancel";
        clicked => $on_cancel();
      }

      [end]
      Gtk.Button {
        label: "Add";
        clicked => $on_confirm();
        styles ["suggested-action"]
      }
    }

    Gtk.Box {
      orientation: vertical;
      spacing: 12;
      margin-start: 16;
      margin-end: 16;
      margin-top: 12;
      margin-bottom: 16;

      Gtk.ListBox {
        selection-mode: none;
        styles ["boxed-list"]

        Adw.EntryRow entry_row {
          title: "Task text";
          entry-activated => $on_confirm();
        }
      }

      Gtk.Box {
        orientation: horizontal;
        spacing: 6;

        Gtk.MenuButton date_btn {
          icon-name: "calendar-today-symbolic";
          tooltip-text: "Due date";
          styles ["flat"]

          popover: Gtk.Popover {
            Gtk.Box {
              orientation: vertical;
              spacing: 8;
              margin-start: 8;
              margin-end: 8;
              margin-top: 8;
              margin-bottom: 8;

              Gtk.Calendar calendar {
                day-selected => $on_date_selected();
              }

              Gtk.Button {
                label: "Clear date";
                clicked => $on_date_cleared();
                styles ["flat"]
              }
            }
          };
        }

        Gtk.MenuButton scheduled_btn {
          icon-name: "alarm-symbolic";
          tooltip-text: "Scheduled date";
          styles ["flat"]

          popover: Gtk.Popover {
            Gtk.Box {
              orientation: vertical;
              spacing: 8;
              margin-start: 8;
              margin-end: 8;
              margin-top: 8;
              margin-bottom: 8;

              Gtk.Calendar scheduled_calendar {
                day-selected => $on_scheduled_selected();
              }

              Gtk.Button {
                label: "Clear date";
                clicked => $on_scheduled_cleared();
                styles ["flat"]
              }
            }
          };
        }

        Gtk.MenuButton starting_btn {
          icon-name: "media-playback-start-symbolic";
          tooltip-text: "Starting date";
          styles ["flat"]

          popover: Gtk.Popover {
            Gtk.Box {
              orientation: vertical;
              spacing: 8;
              margin-start: 8;
              margin-end: 8;
              margin-top: 8;
              margin-bottom: 8;

              Gtk.Calendar starting_calendar {
                day-selected => $on_starting_selected();
              }

              Gtk.Button {
                label: "Clear date";
                clicked => $on_starting_cleared();
                styles ["flat"]
              }
            }
          };
        }

        Gtk.MenuButton priority_btn {
          icon-name: "flag-symbolic";
          tooltip-text: "Priority";
          styles ["flat"]

          popover: Gtk.Popover {
            Gtk.Box {
              orientation: vertical;
              spacing: 4;
              margin-start: 8;
              margin-end: 8;
              margin-top: 8;
              margin-bottom: 8;

              Gtk.Button {
                label: "None";
                clicked => $on_priority_none();
                styles ["flat"]
              }

              Gtk.Button {
                label: "A — Highest";
                clicked => $on_priority_a();
                styles ["flat"]
              }

              Gtk.Button {
                label: "B — High";
                clicked => $on_priority_b();
                styles ["flat"]
              }

              Gtk.Button {
                label: "C — Medium";
                clicked => $on_priority_c();
                styles ["flat"]
              }

              Gtk.Button {
                label: "D — Low";
                clicked => $on_priority_d();
                styles ["flat"]
              }
            }
          };
        }

        Gtk.MenuButton context_btn {
          icon-name: "tag-symbolic";
          tooltip-text: "Labels (@context)";
          styles ["flat"]

          popover: Gtk.Popover {
            Gtk.Box {
              orientation: vertical;
              spacing: 8;
              margin-start: 8;
              margin-end: 8;
              margin-top: 8;
              margin-bottom: 8;

              Gtk.ListBox {
                selection-mode: none;
                styles ["boxed-list"]

                Adw.EntryRow context_entry {
                  title: "New @context";
                  entry-activated => $on_context_entry_activated();
                }
              }

              Gtk.ListBox context_listbox {
                selection-mode: none;
                styles ["boxed-list"]
              }
            }
          };
        }

        Gtk.MenuButton project_btn {
          icon-name: "folder-symbolic";
          tooltip-text: "Project (+project)";
          styles ["flat"]

          popover: Gtk.Popover {
            Gtk.Box {
              orientation: vertical;
              spacing: 8;
              margin-start: 8;
              margin-end: 8;
              margin-top: 8;
              margin-bottom: 8;

              Gtk.ListBox {
                selection-mode: none;
                styles ["boxed-list"]

                Adw.EntryRow project_entry {
                  title: "New +project";
                  entry-activated => $on_project_entry_activated();
                }
              }

              Gtk.ListBox project_listbox {
                selection-mode: none;
                styles ["boxed-list"]
              }
            }
          };
        }
      }

      Gtk.Box preview_box {
        orientation: horizontal;
        spacing: 6;
        margin-top: 4;
      }
    }
  }
}
