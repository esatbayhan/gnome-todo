  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.1.0" date="2026-03-23">
      <description>
        <p>Initial release with core task management features:</p>
        <ul>
          <li>Smart filters for Inbox, Today, Scheduled, Starting, and Completed tasks</li>
          <li>Project and context sidebar navigation</li>
          <li>Inline task editing with detail panel</li>
          <li>Automatic external file change detection</li>
          <li>Keyboard shortcuts for all major actions</li>
        </ul>
      </description>
    </release>
  </releases>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>
</component>
